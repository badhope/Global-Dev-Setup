# Global-Dev-Setup .gitignore
# Comprehensive file to prevent privacy leaks and accidental commits

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*
*.vscode/extensions.json  # Personal extensions
*.vscode/settings.json    # Personal settings
*.vscode/launch.json      # Personal launch configs
*.vscode/tasks.json       # Personal tasks
*.vscode/keybindings.json # Personal keybindings

# Build artifacts
*.o
*.so
*.dylib
*.a
*.lib
*.dll
*.exe
*.pyc
*.pyo
*.pyd
*.class
*.jar
*.war
*.ear
*.log

# Temporary files
.tmp/
.temp/
tmp/
temp/
*.tmp
*.temp
*.cache
*.swp

# Downloaded installers
*.dmg
*.exe
*.msi
*.deb
*.rpm
*.pkg
*.zip
*.tar.gz
*.rar

# Backup files
*.bak
*.backup
*_backup
*.orig
*.rej

# Environment files (CONTAINS SECRETS!)
.env
.env.local
.env.*.local
.env.*
*.env
*.env.*
config.json
config.yaml
config.yml
*.secrets
*.secret
*.key
*.pem
*.pub
*.crt
*.p12
*.pfx
*.keystore
*.jks
*.truststore

# AWS/GCP/Azure configs
.aws/
.gcp/
.azure/
~/.aws/credentials
~/.aws/config
~/.gcloud/
~/.azure/

# Git credentials and config
.gitconfig
.git-credentials
.netrc
.ssh/
ssh_config
id_rsa
id_ed25519
id_ecdsa
id_dsa
*.ppk

# API Keys, Tokens, Secrets
*.key
*.token
*.apikey
*.secret
*key*
*secret*
*token*
*password*
*pass*

# Package manager lock files (optional, can be tracked)
# Uncomment if you want to ignore lock files
# package-lock.json
# yarn.lock
# Pipfile.lock
# poetry.lock

